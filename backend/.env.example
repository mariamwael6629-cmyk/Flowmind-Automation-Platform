# Copy this file to .env and adjust values for your environment.

# Database connection string (SQLite by default, works with zero setup).
# For Postgres use e.g. postgresql://user:password@localhost:5432/flowmind
DATABASE_URL=sqlite:///./flowmind.db

# Secret used to sign JWT access tokens — generate a long random string for production.
SECRET_KEY=change-this-to-a-long-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated list of origins allowed to call the API (your frontend URL(s)).
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000,http://localhost:8000,null

# Optional: real OpenAI key to power the AI assistant with live GPT responses.
# If left empty, FlowMind falls back to a built-in rule-based workflow generator.
OPENAI_API_KEY=

APP_NAME=FlowMind API
DEBUG=true
